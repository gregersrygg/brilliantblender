{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npx playwright test",
            "timeout": 300000,
            "statusMessage": "Running Playwright tests before commit..."
          }
        ]
      }
    ]
  }
}
